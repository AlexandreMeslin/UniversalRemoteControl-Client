<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    tools:context=".fragment.TVSamsungFragment">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <!-- TODO: Update blank fragment layout -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tv_samsung"
                android:textColor="@color/white"
                android:textSize="34sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <ImageButton
                    android:id="@+id/tv_smsng_power"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:backgroundTint="@color/red"
                    android:contentDescription="@string/power"
                    android:src="@drawable/outline_power_settings_new_24_white"
                    android:text="@string/power"
                    android:textColor="@color/white" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp"
                    android:layout_weight="0.5" />

                <Button
                    android:id="@+id/tv_smsng_hdmi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/hdmi"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp"
                    android:layout_weight="0.5" />

                <ImageButton
                    android:id="@+id/tv_smsng_source"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/source"
                    android:src="@drawable/baseline_source_24"
                    android:text="@string/source"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp">

                <Button
                    android:id="@+id/smsng_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_1"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_2"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_3"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp">

                <Button
                    android:id="@+id/smsng_4"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_4"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_5"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_5"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_6"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_6"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp">

                <Button
                    android:id="@+id/smsng_7"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_7"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_8"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_8"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_9"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_9"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp">

                <Button
                    android:id="@+id/smsng_dash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/traco"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_0"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/_0"
                    android:textColor="@color/black" />

                <View
                    android:layout_width="2dp"
                    android:layout_height="0dp" />

                <Button
                    android:id="@+id/smsng_pre_ch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/pre_ch"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/smsng_volume_up"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/volume_up"
                        android:text="@string/plus"
                        android:textColor="@color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/volume" />

                    <Button
                        android:id="@+id/smsng_volume_down"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/volume_down"
                        android:text="@string/minus"
                        android:textColor="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/smsng_mute"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/mute"
                        android:text="@string/mute"
                        android:textColor="@color/black" />

                    <Button
                        android:id="@+id/smsng_ch_list"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/white"
                        android:text="@string/ch_list"
                        android:textColor="@color/black" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/smsng_channel_up"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/white"
                        android:text="@string/plus"
                        android:textColor="@color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/channel" />

                    <Button
                        android:id="@+id/smsng_channel_down"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:backgroundTint="@color/white"
                        android:text="@string/minus"
                        android:textColor="@color/black" />
                </LinearLayout>
            </LinearLayout>

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:columnCount="3"
                android:rowCount="4"
                android:weightSum="3">
                <!-- linha 0 -->
                <Button
                    android:id="@+id/smsng_smart"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_row="0"
                    android:layout_rowWeight="1"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/smart_nhub"
                    android:textColor="@color/black" />

                <ImageButton
                    android:id="@+id/smsng_menu"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_row="0"
                    android:layout_rowWeight="1"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/menu"
                    android:src="@drawable/baseline_menu_24"
                    android:text="@string/menu"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/smsng_guide"
                    android:layout_width="wrap_content"
                    android:layout_height="0dp"
                    android:layout_row="0"
                    android:layout_rowWeight="1"
                    android:layout_column="2"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/guide"
                    android:textColor="@color/black" />
                <!-- Linha 1 -->
                <Button
                    android:id="@+id/smsng_tools"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_row="1"
                    android:layout_rowWeight="1"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/tools"
                    android:textColor="@color/black" />

                <ImageButton
                    android:id="@+id/smsng_up"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_row="1"
                    android:layout_rowWeight="1"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/up"
                    android:src="@drawable/baseline_arrow_circle_up_24"
                    android:text="@string/up"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/smsng_info"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_row="1"
                    android:layout_rowWeight="1"
                    android:layout_column="2"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:text="@string/info"
                    android:textColor="@color/black" />
                <!-- Linha 2 -->
                <ImageButton
                    android:id="@+id/smsng_left"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_row="2"
                    android:layout_rowWeight="1"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/left"
                    android:src="@drawable/outline_arrow_circle_left_24"
                    android:text="@string/left"
                    android:textColor="@color/black" />

                <ImageButton
                    android:id="@+id/smsng_ok"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_row="2"
                    android:layout_rowWeight="1"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/ok"
                    android:src="@drawable/outline_check_circle_24"
                    android:textColor="@color/black" />

                <ImageButton
                    android:id="@+id/smsng_right"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_row="2"
                    android:layout_rowWeight="1"
                    android:layout_column="2"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/right"
                    android:src="@drawable/outline_arrow_circle_right_24"
                    android:textColor="@color/black" />
                <!-- Linha 3 -->
                <ImageButton
                    android:id="@+id/smsng_return"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_row="3"
                    android:layout_rowWeight="1"
                    android:layout_column="0"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/retorna"
                    android:src="@drawable/baseline_return_24"
                    android:textColor="@color/black" />

                <ImageButton
                    android:id="@+id/smsng_down"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_row="3"
                    android:layout_rowWeight="1"
                    android:layout_column="1"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/down"
                    android:rotation="180"
                    android:src="@drawable/baseline_arrow_circle_up_24"
                    android:textColor="@color/black" />

                <ImageButton
                    android:id="@+id/smsng_exit"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_row="3"
                    android:layout_rowWeight="1"
                    android:layout_column="2"
                    android:layout_columnWeight="1"
                    android:backgroundTint="@color/white"
                    android:contentDescription="@string/exit"
                    android:src="@drawable/baseline_exit_to_app_24"
                    android:textColor="@color/black" />
            </GridLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <Button
                    android:id="@+id/smsng_a"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/red"
                    android:text="@string/a"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/smsng_b"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/green"
                    android:text="@string/b"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/smsng_c"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yellow"
                    android:text="@string/smsng_c"
                    android:textColor="@color/black" />

                <Button
                    android:id="@+id/smsng_d"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="@color/blue"
                    android:text="@string/d"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="horizontal">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:columnCount="3"
                    android:rowCount="4">
                    <!-- Linha 0 -->
                    <Button
                        android:id="@+id/smsng_e_manual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="0"
                        android:layout_column="0"
                        android:backgroundTint="@color/white"
                        android:text="@string/e_manual"
                        android:textColor="@color/black" />

                    <Button
                        android:id="@+id/smsng_srs"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="0"
                        android:layout_column="1"
                        android:backgroundTint="@color/white"
                        android:text="@string/srs"
                        android:textColor="@color/black" />

                    <Button
                        android:id="@+id/smsng_p_mode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="0"
                        android:layout_column="2"
                        android:backgroundTint="@color/white"
                        android:text="@string/p_mode"
                        android:textColor="@color/black" />
                    <!-- Linha 1 -->
                    <Button
                        android:id="@+id/smsng_p_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="1"
                        android:layout_column="0"
                        android:backgroundTint="@color/white"
                        android:text="@string/p_size"
                        android:textColor="@color/black" />

                    <Button
                        android:id="@+id/smsng_cc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="1"
                        android:layout_column="1"
                        android:backgroundTint="@color/white"
                        android:text="@string/cc"
                        android:textColor="@color/black" />

                    <Button
                        android:id="@+id/smsng_mts"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="1"
                        android:layout_column="2"
                        android:backgroundTint="@color/white"
                        android:text="@string/mts"
                        android:textColor="@color/black" />
                    <!-- Linha 2 -->
                    <ImageButton
                        android:id="@+id/smsng_rew"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="2"
                        android:layout_column="0"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/rewind"
                        android:src="@drawable/baseline_fast_rewind_24"
                        android:text="@string/rew"
                        android:textColor="@color/black" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="0dp" />

                    <ImageButton
                        android:id="@+id/smsng_pause"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="2"
                        android:layout_column="1"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/pause"
                        android:src="@drawable/baseline_pause_24"
                        android:textColor="@color/black" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="0dp" />

                    <ImageButton
                        android:id="@+id/smsng_fwd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="2"
                        android:layout_column="2"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/forward"
                        android:src="@drawable/baseline_fast_forward_24"
                        android:text="@string/fwd"
                        android:textColor="@color/black" />
                    <!-- Linha 3 -->
                    <ImageButton
                        android:id="@+id/smsng_rec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="3"
                        android:layout_column="0"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/record"
                        android:src="@drawable/baseline_fiber_manual_record_24"
                        android:textColor="@color/black" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="0dp" />

                    <ImageButton
                        android:id="@+id/smsng_play"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="3"
                        android:layout_column="1"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/play"
                        android:src="@drawable/baseline_play_arrow_24"
                        android:text="@string/play"
                        android:textColor="@color/black" />

                    <View
                        android:layout_width="2dp"
                        android:layout_height="0dp" />

                    <ImageButton
                        android:id="@+id/smsng_stop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_row="3"
                        android:layout_column="2"
                        android:backgroundTint="@color/white"
                        android:contentDescription="@string/stop"
                        android:src="@drawable/baseline_stop_circle_24"
                        android:text="@string/stop"
                        android:textColor="@color/black" />
                </GridLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
